{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "module": "nodenext",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,

    /* electrobun ships raw .ts sources (no .d.ts); type-check src/bun against
       our local stub instead of the dependency's unbuildable sources. */
    "paths": {
      "electrobun/bun": ["./types/electrobun.d.ts"]
    },
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "electrobun.config.ts",
    "server/**/*.ts",
    "scripts/**/*.ts",
    "src/bun/**/*.ts",
    "types/**/*.d.ts"
  ]
}
