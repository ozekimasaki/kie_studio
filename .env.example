# Get your key at https://kie.ai/api-key
# Optional: the desktop app can also store the key from its in-app Settings
# screen (persisted in SQLite under the app's user-data dir). The stored key
# takes precedence over this env var.
KIE_API_KEY=your_api_key_here

# Optional
PORT=8787

# Optional: override the SQLite location. The desktop app sets this to a
# writable user-data path automatically; dev falls back to data/studio.db.
# STUDIO_DB_PATH=

# Optional: static host base URL for Electrobun differential auto-updates.
# Leave empty to disable updates (local builds).
# RELEASE_BASE_URL=

# Optional: Grok Build headless auth (if not already logged in via `grok login`)
# https://docs.x.ai/build/overview
# XAI_API_KEY=xai-...

# Catalog sync on server start (default: on, skip if < 12h old)
# SYNC_MODELS_ON_START=0
# SYNC_MODELS_FORCE=1
# SYNC_CONCURRENCY=12
